# Cloudflare Worker API 基础地址
# 本地开发时，Worker 通常运行在 http://localhost:8787
# 生产环境时，应该设置为实际的 Worker URL
VITE_WORKER_API_BASE_URL=http://localhost:8787

# Cloudflare Turnstile 站点密钥（公开）
# 本地开发可使用以下测试密钥（始终通过）：1x00000000000000000000AA
# 生产环境密钥请在 Cloudflare Dashboard > Turnstile 中获取
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
