# 本地开发环境变量示例
# 将此文件复制为 .dev.vars 并填入实际的 API Key
# 注意：.dev.vars 包含敏感信息，已被 .gitignore 忽略，请勿提交到版本控制

# DeepSeek API Key
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxx

# Cloudflare Turnstile Secret Key
# 本地开发可使用以下测试密钥（始终通过）：1x0000000000000000000000000000000AA
# 生产环境密钥请在 Cloudflare Dashboard > Turnstile 中获取
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
